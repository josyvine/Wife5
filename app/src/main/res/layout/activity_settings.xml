<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/editorial_background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarSettings"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/editorial_background"
        app:title="System Settings"
        app:titleTextColor="@color/editorial_primary_dark" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Profile Parameters Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/editorial_border"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/editorial_surface"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="My P2P Signature"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="@color/editorial_primary_dark" />

                    <EditText
                        android:id="@+id/etDeviceName"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="12dp"
                        android:hint="Change alias..."
                        android:paddingHorizontal="12dp"
                        android:background="@android:drawable/editbox_background_normal"
                        android:textColor="@color/editorial_text_primary"
                        android:textColorHint="@color/editorial_text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvSettingDeviceId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="ID: ANDROID_ID_READOUT"
                        android:textSize="12sp"
                        android:textColor="@color/editorial_text_secondary" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Storage Parameters -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/editorial_border"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/editorial_surface"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Storage Maintenance"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="@color/editorial_primary_dark" />

                    <Button
                        android:id="@+id/btnClearChatHistory"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="16dp"
                        android:backgroundTint="#F44336"
                        android:text="Wipe Local Chat Databases"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Metadata parameters -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/editorial_border"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/editorial_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="App Details"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="@color/editorial_primary_dark" />

                    <TextView
                        android:id="@+id/tvVersion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Version: 1.0.0"
                        android:textSize="13sp"
                        android:textColor="@color/editorial_text_secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Secure Wifi Direct Peer communication layer."
                        android:textSize="12sp"
                        android:textColor="@color/editorial_text_secondary" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
