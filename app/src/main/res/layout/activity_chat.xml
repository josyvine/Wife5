<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/editorial_background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarChat"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/editorial_background"
        app:title="Chat Session"
        app:titleTextColor="@color/editorial_primary_dark"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarChat"
        app:layout_constraintBottom_toTopOf="@id/layoutChatInput" />

    <LinearLayout
        android:id="@+id/layoutChatInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/editorial_surface"
        app:layout_constraintBottom_toBottomOf="parent">

        <EditText
            android:id="@+id/etChatMessage"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="Type secure offline message..."
            android:background="@android:color/transparent"
            android:paddingHorizontal="14dp"
            android:inputType="textShortMessage"
            android:textColor="@color/editorial_text_primary"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnSendChatMessage"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:backgroundTint="@color/editorial_accent"
            android:text="Send"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
