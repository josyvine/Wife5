<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/editorial_background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarFileTransfer"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/editorial_background"
        app:title="Mesh File Sharing"
        app:titleTextColor="@color/editorial_primary_dark"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- File pick & active progress layout -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardActiveTransfer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/editorial_border"
        app:strokeWidth="1dp"
        app:cardBackgroundColor="@color/editorial_surface"
        app:layout_constraintTop_toBottomOf="@id/toolbarFileTransfer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select and Transmit Local Files"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/editorial_primary_dark" />

            <Button
                android:id="@+id/btnPickFile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/editorial_accent"
                android:text="Select Document / Image File"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Progress Group -->
            <LinearLayout
                android:id="@+id/layoutTransferProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvActiveFileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Uploading file..."
                    android:textSize="13sp"
                    android:textColor="@color/editorial_primary_dark"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/pbTransferPercentage"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:max="100" />

                <!-- Symmetrical alignment of speed, size and percent text views -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/tvTransferSpeedAndSize"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:text=""
                        android:textSize="12sp"
                        android:textColor="@color/editorial_text_secondary"
                        android:textStyle="normal" />

                    <TextView
                        android:id="@+id/tvTransferPercentText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="0%"
                        android:textSize="12sp"
                        android:textColor="@color/editorial_accent"
                        android:textStyle="bold" />

                </RelativeLayout>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvHistoryHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="Transmission Logs"
        android:textStyle="bold"
        android:textSize="14sp"
        android:textColor="@color/editorial_primary_dark"
        app:layout_constraintTop_toBottomOf="@id/cardActiveTransfer"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFileHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvHistoryHeader"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>