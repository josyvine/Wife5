<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <TextView
        android:id="@+id/tvVoicePeerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="72dp"
        android:text="Offline Peer"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvVoiceCallState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Ringing..."
        android:textColor="#BBBBBB"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvVoicePeerName" />

    <TextView
        android:id="@+id/tvVoiceDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="00:00"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvVoiceCallState" />

    <ImageView
        android:id="@+id/ivVoiceAvatar"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:src="@android:drawable/sym_def_app_icon"
        android:contentDescription="Peer Avatar"
        app:layout_constraintBottom_toTopOf="@id/layoutVoiceControl"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvVoiceDuration" />

    <!-- Control Buttons Group -->
    <LinearLayout
        android:id="@+id/layoutVoiceControl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabMute"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:src="@android:drawable/ic_btn_speak_now"
            app:backgroundTint="#2C2C2C"
            app:tint="#FFFFFF"
            android:contentDescription="Mute Voice" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAcceptVoice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:src="@android:drawable/btn_star_big_on"
            app:backgroundTint="#4CAF50"
            app:tint="#FFFFFF"
            android:visibility="gone"
            android:contentDescription="Accept Call" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabDeclineVoice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:backgroundTint="#F44336"
            app:tint="#FFFFFF"
            android:contentDescription="Decline Call" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabSpeaker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:src="@android:drawable/ic_lock_silent_mode_off"
            app:backgroundTint="#2C2C2C"
            app:tint="#FFFFFF"
            android:contentDescription="Speaker Status" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
